PORT=5000
NODE_ENV=development

# ─────────────────────────────────────────
# MongoDB
# Option A — Local (requires MongoDB installed)
# MONGO_URI=mongodb://localhost:27017/edupath
#
# Option B — MongoDB Atlas (recommended, free tier)
# 1. Go to https://cloud.mongodb.com → create free cluster
# 2. Click Connect → Drivers → copy connection string
# 3. Replace <password> and <dbname> below:
MONGO_URI=#enter you database url paste here
# ─────────────────────────────────────────

# JWT Secrets — generate strong random values:
# Run: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=your_refresh_secret_change_this_too
JWT_REFRESH_EXPIRES_IN=30d

# Anthropic Claude AI
# Get key from: https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-api03-REPLACE_WITH_YOUR_KEY
ANTHROPIC_MODEL=claude-sonnet-4-20250514
ANTHROPIC_MAX_TOKENS=1000

# Frontend origin (React runs on 3000)
CLIENT_ORIGIN=http://localhost:3000

# Bcrypt
BCRYPT_SALT_ROUNDS=12
